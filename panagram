import java.util.HashSet;

String str = "the quick brown fox jumps over the lazy dog";
str = str.toLowerCase();

HashSet<Character> set = new HashSet<>();

for (char ch : str.toCharArray()) {
    if (ch >= 'a' && ch <= 'z') {
        set.add(ch);
    }
}

if (set.size() == 26) {
    System.out.println("Pangram");
} else {
    System.out.println("Not Pangram");
}
